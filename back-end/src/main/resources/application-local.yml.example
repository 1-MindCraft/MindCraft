spring:
  datasource:
    url: jdbc:postgresql://<RDS-엔드포인트>:5432/<DB이름>
    username: <사용자명>
    password: <비밀번호>
  jpa:
    hibernate:
      ddl-auto: update
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: <발급받은 값>
            client-secret: <발급받은 값>
          kakao:
            client-id: <발급받은 값>
            client-secret: <발급받은 값>
          naver:
            client-id: <발급받은 값>
            client-secret: <발급받은 값>

jwt:
  secret: <비밀키>

ai:
  server:
    base-url: ${AI_SERVER_URL}

server:
  forward-headers-strategy: framework

frontend:
  url: ${FRONTEND_URL}